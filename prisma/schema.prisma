// PMO Agent — Organizational Planning Unit schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Team members (manager + staff across 4 departments) ----
model Member {
  id         String   @id @default(cuid())
  name       String
  handle     String   @unique // telegram handle or internal id, e.g. @ali
  department String   // FANTASY | NON_FANTASY | BI | COMMISSION
  role       String   @default("MEMBER") // MANAGER | MEMBER
  avatar     String?
  createdAt  DateTime @default(now())
  tasks      Task[]
}

// ---- Tasks ----
model Task {
  id             String   @id @default(cuid())
  code           String   @unique // human readable, e.g. TSK-0001
  title          String
  description    String?
  department     String   // FANTASY | NON_FANTASY | BI | COMMISSION
  assigneeId     String
  assignee       Member   @relation(fields: [assigneeId], references: [id])
  priority       String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  status         String   @default("PENDING") // PENDING | STARTED | BLOCKED | DONE
  deadline       DateTime
  link           String?
  followUpReason String?  // DEPENDENT_ON_OTHERS | LACK_OF_INFO | HIGH_WORKLOAD | TECHNICAL_ISSUE | OTHER
  startedAt      DateTime?
  doneAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  logs           FollowUpLog[]
}

// ---- Follow-up / activity log per task ----
model FollowUpLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      String   // STATUS_CHANGE | MORNING_BRIEF | OVERDUE_NUDGE | END_OF_DAY_REASON | NOTE
  message   String
  reason    String?
  createdAt DateTime @default(now())
}

// ---- Daily reports (morning briefings + evening manager reports) ----
model DailyReport {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD (Asia/Tehran)
  morning   String?  // JSON-serialized morning briefing payload
  evening   String?  // JSON-serialized evening manager report payload
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
